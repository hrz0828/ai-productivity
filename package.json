{
  "name": "ai-productivity",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "check:content-dates": "node scripts/check-content-dates.mjs",
    "check:seo": "node scripts/check-seo.mjs",
    "build:site": "astro check && astro build && pagefind --site dist",
    "build": "npm run check:content-dates && npm run build:site",
    "preview": "npm run build:site && wrangler dev",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "npm run build:site && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/check": "latest",
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/mdx": "latest",
    "@astrojs/rss": "latest",
    "@astrojs/sitemap": "latest",
    "@tailwindcss/typography": "latest",
    "@tailwindcss/vite": "latest",
    "astro": "latest",
    "pagefind": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "wrangler": "^4.112.0"
  }
}
