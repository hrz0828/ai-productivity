---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import TagList from '../components/TagList.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import AdsenseBlock from '../components/AdsenseBlock.astro';
import { COLLECTION_LABELS } from '../config';
import { articleJsonLd, breadcrumbJsonLd, formatDate } from '../utils/seo';
import { getReadingTime } from '../utils/readingTime';
import type { CollectionName, AnyContentEntry } from '../utils/content';

type Entry = CollectionEntry<'prompts'> | CollectionEntry<'skills'> | CollectionEntry<'agents'> | CollectionEntry<'tools'> | CollectionEntry<'workflows'> | CollectionEntry<'guides'>;

interface Props {
  entry: Entry;
  collection: CollectionName;
  headings: Array<{ depth: number; slug: string; text: string }>;
  body: string;
  related?: AnyContentEntry[];
}

const { entry, collection, headings, body, related = [] } = Astro.props;
const title = entry.data.seoTitle ?? entry.data.title;
const description = entry.data.seoDescription ?? entry.data.description;
const canonical = `/${collection}/${entry.id}/`;
const breadcrumbs = [
  { label: '首页', href: '/' },
  { label: COLLECTION_LABELS[collection], href: `/${collection}/` },
  { label: entry.data.title, href: canonical },
];
const jsonLd = [
  articleJsonLd({
    title: entry.data.title,
    description,
    url: canonical,
    pubDate: entry.data.pubDate,
    updatedDate: entry.data.updatedDate,
    author: entry.data.author,
    image: entry.data.ogImage,
  }),
  breadcrumbJsonLd(breadcrumbs),
];
---

<BaseLayout title={title} description={description} canonical={canonical} image={entry.data.ogImage} type="article" jsonLd={jsonLd}>
  <article class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[minmax(0,1fr)_280px] lg:px-8">
    <div class="min-w-0">
      <Breadcrumb items={breadcrumbs} />
      <header class="mt-8 rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="flex flex-wrap items-center gap-3 text-sm text-slate-500">
          <span class="rounded-full bg-sky-50 px-3 py-1 font-medium text-sky-700">{entry.data.category}</span>
          <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
          <span>{getReadingTime(body)}</span>
        </div>
        <h1 class="mt-5 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">{entry.data.title}</h1>
        <p class="mt-5 text-lg leading-8 text-slate-600">{entry.data.description}</p>
        <div class="mt-6"><TagList tags={entry.data.tags} /></div>
      </header>

      <AdsenseBlock />

      <div class="prose prose-slate mt-8 max-w-none rounded-3xl border border-slate-200 bg-white p-8 prose-a:text-sky-700 prose-pre:bg-slate-950">
        <slot />
        <hr />
        <h2>延伸阅读</h2>
        <ul>
          <li><a href="/guides/prompt-skill-agent-workflow/">Prompt、Skill、Agent、Workflow 有什么区别？</a></li>
          <li><a href="/guides/ai-productivity-guide/">AI 工作流入门指南</a></li>
          <li><a href={`/${collection}/`}>返回 {COLLECTION_LABELS[collection]} 栏目</a></li>
        </ul>
      </div>

      <RelatedArticles entries={related} collection={collection} />
    </div>

    <div class="hidden lg:block">
      <div class="sticky top-24 space-y-6">
        <TableOfContents headings={headings} />
        <AdsenseBlock />
      </div>
    </div>
  </article>
</BaseLayout>
