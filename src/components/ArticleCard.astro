---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/seo';

type Entry = CollectionEntry<'prompts'> | CollectionEntry<'skills'> | CollectionEntry<'agents'> | CollectionEntry<'tools'> | CollectionEntry<'workflows'> | CollectionEntry<'guides'>;

interface Props {
  entry: Entry;
  collection: string;
}

const { entry, collection } = Astro.props;
const href = `/${collection}/${entry.id}/`;
const typeLabels: Record<string, string> = {
  prompts: 'Prompt · 可复制模板',
  skills: 'Skill · 可复用能力',
  agents: 'Agent · 角色配置',
  tools: 'Tool · 工具教程',
  workflows: 'Workflow · 完整流程',
  guides: 'Guide · 方法指南',
};
const typeLabel = typeLabels[collection] ?? collection;
---

<article class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-sky-200 hover:shadow-lg">
  <div class="flex flex-wrap items-center gap-2 text-xs font-medium text-slate-500">
    <span class="rounded-full bg-sky-50 px-3 py-1 text-sky-700">{typeLabel}</span>
    <span class="rounded-full bg-slate-100 px-3 py-1 text-slate-600">{entry.data.category}</span>
    <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
  </div>
  <h2 class="mt-4 text-xl font-semibold leading-snug text-slate-950 group-hover:text-sky-700">
    <a href={href}>{entry.data.title}</a>
  </h2>
  <p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-600">{entry.data.description}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    {entry.data.tags.slice(0, 4).map((tag) => (
      <a href={`/tags/${encodeURIComponent(tag)}/`} class="rounded-full bg-slate-100 px-2.5 py-1 text-xs text-slate-600 transition hover:bg-sky-50 hover:text-sky-700">#{tag}</a>
    ))}
  </div>
</article>
