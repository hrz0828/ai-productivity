---
interface Props {
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { headings } = Astro.props;
const stepHeadings = headings
  .filter((heading) => heading.depth === 2)
  .filter((heading) => /^(step\s*\d+|第[一二三四五六七八九十0-9]+步|步骤|prompt|输入|输出|注意|检查|适用|示例)/i.test(heading.text) || heading.text.length <= 18)
  .slice(0, 8);
---

{stepHeadings.length >= 3 && (
  <section class="mt-8 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Steps</p>
        <h2 class="mt-1 text-2xl font-bold text-slate-950">本文执行路径</h2>
      </div>
      <span class="text-sm text-slate-500">适合先扫一遍，再逐步操作</span>
    </div>
    <ol class="mt-5 grid gap-3 sm:grid-cols-2">
      {stepHeadings.map((heading, index) => (
        <li>
          <a href={`#${heading.slug}`} class="flex gap-3 rounded-2xl border border-slate-200 bg-slate-50 p-4 transition hover:border-sky-200 hover:bg-sky-50">
            <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-white text-xs font-bold text-sky-700 shadow-sm">{index + 1}</span>
            <span class="text-sm font-semibold leading-6 text-slate-800">{heading.text}</span>
          </a>
        </li>
      ))}
    </ol>
  </section>
)}
