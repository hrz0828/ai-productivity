---
interface Props {
  slot?: string;
}
const { slot } = Astro.props;
const clientId = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;
---

{clientId && slot && (
  <div class="my-8 text-center">
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={clientId}
      data-ad-slot={slot}
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
    <script is:inline>
      try {
        (window.adsbygoogle = window.adsbygoogle || []).push({});
      } catch (error) {}
    </script>
  </div>
)}
