---
interface Props {
  tags: string[];
}
const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {tags.map((tag) => (
    <a href={`/tags/${encodeURIComponent(tag)}/`} class="rounded-full bg-slate-100 px-3 py-1 text-sm text-slate-600 transition hover:bg-sky-50 hover:text-sky-700">#{tag}</a>
  ))}
</div>
