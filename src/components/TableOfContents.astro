---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const items = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

{items.length > 0 && (
  <aside class="rounded-3xl border border-slate-200 bg-white p-5">
    <div class="font-semibold text-slate-950">目录</div>
    <ol class="mt-3 space-y-2 text-sm text-slate-600">
      {items.map((heading) => (
        <li class={heading.depth === 3 ? 'pl-4' : ''}>
          <a class="hover:text-sky-700" href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))}
    </ol>
  </aside>
)}
