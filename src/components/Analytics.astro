---
const gaId = import.meta.env.PUBLIC_GA_ID;
const cloudflareToken = import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN;
---

{gaId && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
    <script is:inline define:vars={{ gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  </>
)}

{cloudflareToken && (
  <script
    is:inline
    defer
    src="https://static.cloudflareinsights.com/beacon.min.js"
    data-cf-beacon={`{"token":"${cloudflareToken}"}`}
  ></script>
)}

<script is:inline>
  window.trackInteraction = window.trackInteraction || function trackInteraction(eventName, payload = {}) {
    if (!eventName) return;

    const enrichedPayload = {
      page_path: window.location.pathname,
      page_title: document.title,
      referrer: document.referrer || undefined,
      timestamp: new Date().toISOString(),
      ...payload,
    };

    if (typeof window.gtag === 'function') {
      window.gtag('event', eventName, enrichedPayload);
    }

    if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
      console.debug('[interaction]', eventName, enrichedPayload);
    }
  };
</script>
