---
const quickPrompts = [
  {
    id: 'weekly-report',
    title: '周报生成 Prompt',
    scene: '把零散工作记录整理成结构化周报',
    audience: '职场人 / 项目成员 / 团队负责人',
    description: '适合每周五快速整理成果、问题、数据和下周计划。',
    href: '/prompts/ai-weekly-report-prompt/',
    prompt: `你是一名专业的职场写作助理。请根据我提供的本周工作信息，帮我生成一份结构清晰、表达专业、重点突出的工作周报。

请按照以下结构输出：
1. 本周核心成果
2. 重点工作进展
3. 数据或结果说明
4. 遇到的问题与风险
5. 下周计划
6. 需要协同或支持的事项

写作要求：
- 语言简洁、正式，适合发给直属领导或项目组
- 不要夸大事实
- 对零散事项进行归类和提炼
- 如果信息不足，请用“待补充”标记

以下是我的原始信息：
[在这里粘贴本周工作记录]`,
  },
  {
    id: 'resume-optimization',
    title: '简历优化 Prompt',
    scene: '根据目标岗位 JD 优化简历表达',
    audience: '求职者 / 转岗人群 / 职场新人',
    description: '帮助提炼项目成果、匹配关键词，并标记需要补充的数据。',
    href: '/prompts/ai-resume-optimization-prompt/',
    prompt: `你是一名专业简历顾问。请根据我的简历内容和目标岗位 JD，帮我优化简历表达。

要求：
- 不编造经历
- 优先突出与 JD 匹配的能力
- 把职责描述改成成果导向表达
- 标记需要我补充数据的地方
- 输出修改建议和改写版本

我的简历片段：
[粘贴简历]

目标岗位 JD：
[粘贴 JD]`,
  },
  {
    id: 'prd-draft',
    title: 'PRD 初稿 Prompt',
    scene: '把需求想法整理成产品需求文档',
    audience: '产品经理 / 创业者 / 项目负责人',
    description: '从背景、目标、用户故事、功能规则到验收标准生成 PRD 框架。',
    href: '/prompts/ai-prd-prompt/',
    prompt: `你是一名经验丰富的产品经理。请根据我提供的需求背景，生成一份结构清晰、可继续评审的 PRD 初稿。

请按照以下结构输出：
1. 需求背景
2. 目标用户
3. 用户问题
4. 产品目标
5. 核心功能列表
6. 用户故事
7. 功能规则与边界
8. 验收标准
9. 风险与待确认问题

写作要求：
- 不要编造未提供的业务事实
- 信息不足时用“待确认”标记
- 先保证结构完整，再给出可执行建议

需求背景：
[在这里粘贴需求想法、用户反馈或业务目标]`,
  },
  {
    id: 'meeting-minutes',
    title: '会议纪要 Prompt',
    scene: '从会议记录中提炼结论与行动项',
    audience: '项目经理 / 运营 / 团队协作成员',
    description: '快速整理议题、决策、责任人、截止时间和待跟进风险。',
    href: '/prompts/ai-meeting-minutes-prompt/',
    prompt: `你是一名专业会议纪要助理。请根据我提供的会议记录，整理一份结构清晰、方便会后跟进的会议纪要。

请输出：
1. 会议主题
2. 参会人员与角色
3. 核心讨论内容
4. 已确认结论
5. 行动项表格（事项 / 负责人 / 截止时间 / 状态）
6. 风险与待确认问题
7. 会后跟进建议

要求：
- 不要添加会议中没有出现的信息
- 责任人或时间不明确时标记“待确认”
- 行动项必须具体、可执行

会议记录：
[在这里粘贴会议录音转写或会议笔记]`,
  },
];
---

<section id="quick-prompts" class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
  <div class="rounded-[2rem] border border-sky-100 bg-gradient-to-br from-white via-sky-50/50 to-white p-6 shadow-sm sm:p-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Quick copy</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-950">热门 Prompt，首页直接复制使用</h2>
        <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">不用先跳转到详情页。选择一个高频场景，预览后复制到 ChatGPT、Claude 或 Gemini 即可开始。</p>
      </div>
      <a href="/prompts/" class="inline-flex rounded-full border border-sky-200 bg-white px-5 py-2.5 text-sm font-semibold text-sky-700 transition hover:border-sky-300 hover:bg-sky-50">查看全部 Prompt →</a>
    </div>

    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {quickPrompts.map((item) => (
        <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-sky-200 hover:shadow-lg">
          <div class="flex flex-wrap items-center gap-2 text-xs font-medium text-slate-500">
            <span class="rounded-full bg-sky-50 px-3 py-1 text-sky-700">Prompt</span>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-slate-600">{item.scene}</span>
          </div>
          <h3 class="mt-4 text-xl font-semibold text-slate-950">{item.title}</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">{item.description}</p>
          <p class="mt-3 text-xs leading-5 text-slate-500">适合：{item.audience}</p>
          <details class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 p-4" data-quick-details={item.id}>
            <summary class="cursor-pointer text-sm font-semibold text-slate-800 marker:text-sky-600">展开预览片段</summary>
            <pre class="mt-3 max-h-52 overflow-auto whitespace-pre-wrap text-xs leading-6 text-slate-700">{item.prompt}</pre>
          </details>
          <p class="mt-3 hidden text-sm font-medium text-sky-700" data-quick-status={item.id} aria-live="polite"></p>
          <div class="mt-5 flex flex-wrap gap-3">
            <button type="button" class="rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800" data-quick-preview={item.id}>快速预览</button>
            <button type="button" class="rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-sky-300 hover:text-sky-700" data-quick-copy={item.id}>复制 Prompt</button>
            <a href={item.href} class="inline-flex items-center text-sm font-semibold text-sky-700 hover:text-sky-900">完整教程 →</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<div class="fixed inset-0 z-50 hidden items-end bg-slate-950/50 p-0 backdrop-blur-sm sm:items-center sm:p-4" data-quick-modal aria-hidden="true">
  <div class="mx-auto max-h-[88vh] w-full max-w-3xl overflow-hidden rounded-t-[2rem] bg-white shadow-2xl sm:rounded-[2rem]" role="dialog" aria-modal="true" aria-labelledby="quick-prompt-title">
    <div class="flex items-start justify-between gap-4 border-b border-slate-200 p-5 sm:p-6">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Prompt preview</p>
        <h2 id="quick-prompt-title" class="mt-1 text-2xl font-bold text-slate-950" data-quick-modal-title></h2>
        <p class="mt-2 text-sm leading-6 text-slate-600" data-quick-modal-description></p>
      </div>
      <button type="button" class="rounded-full border border-slate-200 px-3 py-1.5 text-sm font-semibold text-slate-600 transition hover:border-slate-300 hover:text-slate-950" data-quick-close aria-label="关闭 Prompt 预览">关闭</button>
    </div>
    <div class="max-h-[52vh] overflow-auto bg-slate-950 p-5 sm:p-6">
      <pre class="whitespace-pre-wrap text-sm leading-7 text-slate-100"><code data-quick-modal-prompt></code></pre>
    </div>
    <div class="flex flex-col gap-3 border-t border-slate-200 p-5 sm:flex-row sm:items-center sm:justify-between sm:p-6">
      <p class="text-sm text-slate-500">复制后把方括号里的占位内容替换成你的真实材料。</p>
      <div class="flex gap-3">
        <button type="button" class="rounded-full bg-sky-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-sky-700" data-quick-modal-copy>复制这个 Prompt</button>
        <a href="#" class="rounded-full border border-slate-200 px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-sky-300 hover:text-sky-700" data-quick-modal-link>查看教程</a>
      </div>
    </div>
  </div>
</div>

<div class="fixed bottom-5 left-1/2 z-[60] hidden w-[calc(100%-2rem)] max-w-sm -translate-x-1/2 rounded-2xl border border-slate-200 bg-white p-4 text-sm font-medium text-slate-700 shadow-2xl sm:right-5 sm:left-auto sm:w-full sm:translate-x-0" data-quick-toast role="status" aria-live="polite"></div>

<script is:inline define:vars={{ quickPrompts }}>
  const prompts = new Map(quickPrompts.map((item) => [item.id, item]));
  const modal = document.querySelector('[data-quick-modal]');
  const title = document.querySelector('[data-quick-modal-title]');
  const description = document.querySelector('[data-quick-modal-description]');
  const promptText = document.querySelector('[data-quick-modal-prompt]');
  const modalCopy = document.querySelector('[data-quick-modal-copy]');
  const modalLink = document.querySelector('[data-quick-modal-link]');
  const toast = document.querySelector('[data-quick-toast]');
  let activePrompt;
  let toastTimer;

  function track(eventName, payload) {
    window.trackInteraction?.(eventName, payload);
  }

  function showToast(message, tone = 'success') {
    if (!toast) return;
    window.clearTimeout(toastTimer);
    toast.textContent = message;
    toast.classList.remove('hidden', 'border-slate-200', 'border-sky-200', 'border-amber-200', 'text-slate-700', 'text-sky-800', 'text-amber-800', 'bg-white', 'bg-sky-50', 'bg-amber-50');
    if (tone === 'warning') {
      toast.classList.add('border-amber-200', 'bg-amber-50', 'text-amber-800');
    } else {
      toast.classList.add('border-sky-200', 'bg-sky-50', 'text-sky-800');
    }
    toastTimer = window.setTimeout(() => toast.classList.add('hidden'), 2800);
  }

  function showStatus(item, message, tone = 'success') {
    const status = item ? document.querySelector(`[data-quick-status="${item.id}"]`) : null;
    if (status) {
      status.textContent = message;
      status.classList.remove('hidden', 'text-sky-700', 'text-amber-700');
      status.classList.add(tone === 'warning' ? 'text-amber-700' : 'text-sky-700');
      window.setTimeout(() => status.classList.add('hidden'), 2400);
    }
    showToast(message, tone);
  }

  async function copyPrompt(item, button) {
    if (!item) return;
    const originalText = button?.textContent;
    if (!navigator.clipboard?.writeText) {
      if (button) button.textContent = '请手动复制';
      openModal(item);
      showStatus(item, '当前浏览器不支持一键复制，已打开预览，可手动选择复制。', 'warning');
      if (button && originalText) window.setTimeout(() => { button.textContent = originalText; }, 1800);
      return;
    }
    try {
      await navigator.clipboard.writeText(item.prompt);
      if (button) button.textContent = '已复制 ✓';
      showStatus(item, 'Prompt 已复制，可以直接粘贴到 AI 工具中使用。');
      track('prompt_copy', { prompt_id: item.id, prompt_title: item.title, source: 'quick_prompt_showcase' });
    } catch (error) {
      if (button) button.textContent = '复制失败';
      openModal(item);
      showStatus(item, '复制失败，已打开预览，可手动选择复制。', 'warning');
    } finally {
      if (button && originalText) {
        window.setTimeout(() => { button.textContent = originalText; }, 1800);
      }
    }
  }

  function openModal(item) {
    if (!modal || !item) return;
    activePrompt = item;
    title.textContent = item.title;
    description.textContent = `${item.scene}｜适合：${item.audience}`;
    promptText.textContent = item.prompt;
    modalLink.href = item.href;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    track('prompt_preview_open', { prompt_id: item.id, prompt_title: item.title, source: 'quick_prompt_showcase' });
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-quick-preview]').forEach((button) => {
    button.addEventListener('click', () => {
      const item = prompts.get(button.dataset.quickPreview);
      const details = item ? document.querySelector(`[data-quick-details="${item.id}"]`) : null;
      if (details) details.open = true;
      openModal(item);
    });
  });

  document.querySelectorAll('[data-quick-copy]').forEach((button) => {
    button.addEventListener('click', () => copyPrompt(prompts.get(button.dataset.quickCopy), button));
  });

  document.querySelector('[data-quick-close]')?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (event) => {
    if (event.target === modal) closeModal();
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeModal();
  });
  modalCopy?.addEventListener('click', () => copyPrompt(activePrompt, modalCopy));
</script>
