<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.prose pre').forEach((pre, index) => {
      if (pre.querySelector('[data-copy-code]')) return;

      const button = document.createElement('button');
      button.type = 'button';
      button.textContent = '复制';
      button.setAttribute('data-copy-code', 'true');
      button.setAttribute('aria-label', '复制代码块内容');
      button.className = 'absolute right-3 top-3 rounded-lg bg-white/10 px-2.5 py-1 text-xs font-medium text-white transition hover:bg-white/20 focus:outline-none focus:ring-2 focus:ring-white/40';

      pre.style.position = 'relative';
      pre.appendChild(button);

      button.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        const text = code?.textContent ?? '';
        try {
          await navigator.clipboard.writeText(text);
          button.textContent = '已复制';
          window.trackInteraction?.('code_copy', {
            code_block_index: index,
            page_path: window.location.pathname,
          });
          window.setTimeout(() => { button.textContent = '复制'; }, 1500);
        } catch (error) {
          button.textContent = '复制失败，请手动复制';
          window.setTimeout(() => { button.textContent = '复制'; }, 2000);
        }
      });
    });
  });
</script>
