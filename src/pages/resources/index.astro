---
import BaseLayout from '../../layouts/BaseLayout.astro';

const glossary = [
  { term: 'Prompt', cn: '提示词 / 给 AI 的任务指令', desc: '告诉 AI 要做什么、基于什么材料、按什么格式输出。适合一次性任务，例如写周报、改邮件、生成大纲。' },
  { term: 'Skill', cn: '技能模块 / 可复用的 AI 能力', desc: '把一类任务的输入、步骤、输出和边界沉淀下来，适合反复复用，例如会议纪要整理 Skill。' },
  { term: 'Agent', cn: '智能体 / 带目标和工具的 AI 助手', desc: '具备角色、目标、工作流程和约束的 AI 助手，适合持续处理某类问题，例如产品经理 Agent。' },
  { term: 'Workflow', cn: '工作流 / 多步骤任务流程', desc: '把 Prompt、Skill、工具和人工检查点串起来，完成从输入到产出的复杂任务。' },
  { term: 'Brief', cn: '创作简报 / 任务说明书', desc: '给写作者、设计师或 AI 的任务说明，通常包含目标、受众、背景、素材、风格和交付要求。' },
  { term: 'CTA', cn: '行动号召 / 转化引导话术', desc: '引导用户点击、注册、下载、咨询或购买的文字，例如“立即查看模板”。' },
  { term: 'JD', cn: '岗位说明 / 招聘职位描述', desc: '招聘场景中的职位说明，通常包含职责、要求、加分项、薪资范围和团队介绍。' },
  { term: 'PRD', cn: '产品需求文档', desc: '产品经理用于描述需求背景、目标、用户故事、功能规则、验收标准和风险的文档。' },
  { term: 'SEO', cn: '搜索引擎优化', desc: '通过内容结构、关键词、内链、页面体验和技术配置，让页面更容易被搜索引擎理解和收录。' },
  { term: 'SOP', cn: '标准作业流程', desc: '把一项重复工作拆成稳定步骤、责任人、输入输出和检查点，方便团队执行和复盘。' },
];
const topicResources = [
  { title: 'AI 产品经理', href: '/topics/ai-product-manager/', desc: '需求分析、PRD、产品经理 Agent 和竞品分析。' },
  { title: 'AI 知识管理', href: '/topics/ai-knowledge-management/', desc: 'Notion、Obsidian、资料总结和个人知识库。' },
  { title: 'AI 设计评审', href: '/topics/ai-design-review/', desc: 'Figma、设计 Brief、页面评审和用户体验检查。' },
  { title: 'AI 写作', href: '/topics/ai-writing/', desc: '周报、邮件、PRD、SEO 文章和内容创作。' },
  { title: 'AI 编程', href: '/topics/ai-coding/', desc: 'Claude Code、Cursor、代码审查和部署自动化。' },
  { title: 'AI 会议效率', href: '/topics/ai-meeting-efficiency/', desc: '会议纪要、行动项、会后跟进和会议 Agent。' },
  { title: 'AI 自动化', href: '/topics/ai-automation/', desc: 'n8n、自动化工具和重复任务工作流。' },
];
---
<BaseLayout title="Resources - ai-productivity" description="AI 生产力资源合集，包括 Prompt 模板、Skill 模板、Agent 配置、Workflow 检查清单和 AI 生产力术语表。" canonical="/resources/">
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Resources</p>
    <h1 class="mt-3 text-4xl font-bold text-slate-950">AI 生产力资源合集</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">这里汇总本站最适合复用的模板、工作流、工具教程和术语解释，帮助你从具体任务开始搭建自己的 AI 工作系统。</p>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      <a href="/prompts/" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-sky-200 hover:shadow-lg">
        <h2 class="text-xl font-semibold text-slate-950">Prompt 模板</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">日报、周报、会议纪要、PRD、PPT 大纲、代码审查和竞品分析提示词。</p>
      </a>
      <a href="/workflows/" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-sky-200 hover:shadow-lg">
        <h2 class="text-xl font-semibold text-slate-950">Workflow 案例</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">从输入到输出的完整 AI 工作流，覆盖文档、PPT、代码、研究和知识管理。</p>
      </a>
      <a href="/agents/" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-sky-200 hover:shadow-lg">
        <h2 class="text-xl font-semibold text-slate-950">Agent 配置</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">产品经理、研究助理、代码审查、PPT 策划和 SEO 编辑 Agent 示例。</p>
      </a>
      <a href="/tasks/" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-sky-200 hover:shadow-lg">
        <h2 class="text-xl font-semibold text-slate-950">按任务找工具</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">从写周报、做 PRD、竞品分析、代码审查等具体任务进入推荐路径。</p>
      </a>
      <a href="/submit-prompt/" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-sky-200 hover:shadow-lg">
        <h2 class="text-xl font-semibold text-slate-950">提交你的 Prompt</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">分享你在真实工作中验证有效的 Prompt，帮助更多用户复用。</p>
      </a>
      <a href="/feedback/" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-sky-200 hover:shadow-lg">
        <h2 class="text-xl font-semibold text-slate-950">内容反馈与催更</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">反馈过时信息、工具改版、Prompt 效果问题或新的选题建议。</p>
      </a>
      <a href="/analytics-plan/" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-sky-200 hover:shadow-lg">
        <h2 class="text-xl font-semibold text-slate-950">运营埋点方案</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">查看当前交互事件、内容热度公式和后续数据化运营路径。</p>
      </a>
    </div>

    <div class="mt-12 grid gap-6">
      <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Learning paths</p>
            <h2 class="mt-2 text-2xl font-bold text-slate-950">按专题学习</h2>
          </div>
          <a href="/topics/ai-writing/" class="text-sm font-medium text-sky-700 hover:text-sky-900">查看专题入口 →</a>
        </div>
        <p class="mt-3 text-sm leading-6 text-slate-600">如果你不想按 Prompt、Skill、Agent、Workflow 分类阅读，可以直接按工作场景进入专题。</p>
        <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {topicResources.map((topic) => (
            <a href={topic.href} class="rounded-2xl border border-slate-200 bg-slate-50 p-5 transition hover:border-sky-200 hover:bg-sky-50">
              <h3 class="font-semibold text-slate-950">{topic.title}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-600">{topic.desc}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-bold text-slate-950">AI 生产力术语表</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">本站保留常见英文术语，但每个概念都提供中文解释，方便跨行业新手理解。</p>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {glossary.map((item) => (
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
              <div class="flex flex-wrap items-center gap-2">
                <h3 class="text-lg font-semibold text-slate-950">{item.term}</h3>
                <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-sky-700">{item.cn}</span>
              </div>
              <p class="mt-3 text-sm leading-6 text-slate-600">{item.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-bold text-slate-950">通用 Prompt 模板</h2>
        <pre class="mt-5 overflow-x-auto rounded-2xl bg-slate-950 p-5 text-sm leading-6 text-slate-100"><code>你是[角色]，擅长[能力]。

任务目标：
[说明要完成什么]

背景信息：
[说明为什么做]

输入材料：
[粘贴内容]

处理步骤：
1. [步骤一]
2. [步骤二]
3. [步骤三]

输出格式：
[Markdown / 表格 / JSON / 邮件]

约束：
- 不要编造事实
- 信息不足请标记待补充
- 语言风格为[风格]</code></pre>
      </section>

      <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-bold text-slate-950">Skill 设计模板</h2>
        <pre class="mt-5 overflow-x-auto rounded-2xl bg-slate-950 p-5 text-sm leading-6 text-slate-100"><code># Skill 名称

## 解决什么问题
[说明这个 Skill 面向的高频任务]

## 输入要求
- 输入 1
- 输入 2
- 输入 3

## 执行步骤
1. 理解目标
2. 整理输入
3. 生成输出
4. 检查风险

## 输出格式
[说明固定输出结构]

## 使用边界
[说明不能自动判断或需要人工复核的部分]</code></pre>
      </section>

      <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-bold text-slate-950">Agent 配置模板</h2>
        <pre class="mt-5 overflow-x-auto rounded-2xl bg-slate-950 p-5 text-sm leading-6 text-slate-100"><code>你是[Agent 角色]，擅长[领域能力]。

目标：
[说明 Agent 要持续帮助用户完成什么]

工作方式：
1. 先澄清目标和输入
2. 再拆解任务步骤
3. 输出结构化结果
4. 标记假设、风险和待确认问题

约束：
- 不编造事实或数据
- 高风险动作必须等待用户确认
- 信息不足时先提问

输出格式：
## 任务理解
## 执行步骤
## 输出结果
## 风险和待确认问题</code></pre>
      </section>

      <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-bold text-slate-950">Workflow 检查清单</h2>
        <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-700">
          <li>✅ 是否明确最终产出？</li>
          <li>✅ 是否定义输入字段？</li>
          <li>✅ 是否拆分为多个步骤？</li>
          <li>✅ 是否有人工复核点？</li>
          <li>✅ 是否有输出格式？</li>
          <li>✅ 是否能沉淀为下次复用的模板？</li>
        </ul>
      </section>
    </div>
  </section>
</BaseLayout>
