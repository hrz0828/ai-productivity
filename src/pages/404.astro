---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="页面未找到 - ai-productivity" description="你访问的页面不存在。" canonical="/404/">
  <section class="mx-auto max-w-3xl px-4 py-24 text-center sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-wide text-sky-700">404</p>
    <h1 class="mt-4 text-4xl font-bold text-slate-950">页面未找到</h1>
    <p class="mt-4 text-slate-600">你访问的页面可能已移动或不存在。</p>
    <a href="/" class="mt-8 inline-flex rounded-full bg-slate-950 px-6 py-3 text-sm font-semibold text-white hover:bg-sky-700">返回首页</a>
  </section>
</BaseLayout>
