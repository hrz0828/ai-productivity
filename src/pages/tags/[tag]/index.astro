---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getAllPublishedEntries } from '../../../utils/content';

export async function getStaticPaths() {
  const entries = await getAllPublishedEntries();
  const tags = [...new Set(entries.flatMap((entry) => entry.data.tags))];
  return tags.map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.props;
const entries = (await getAllPublishedEntries()).filter((entry) => entry.data.tags.includes(tag));
---

<BaseLayout title={`#${tag} - 标签 - ai-productivity`} description={`浏览 ai-productivity 中 #${tag} 标签下的 AI 生产力文章。`} canonical={`/tags/${encodeURIComponent(tag)}/`}>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Tag</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">#{tag}</h1>
    <p class="mt-5 text-lg text-slate-600">共 {entries.length} 篇内容。</p>
    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {entries.map((entry) => <ArticleCard entry={entry} collection={entry.collection} />)}
    </div>
  </section>
</BaseLayout>
