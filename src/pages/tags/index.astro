---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPublishedEntries } from '../../utils/content';

const entries = await getAllPublishedEntries();
const tagCounts = entries.reduce((acc, entry) => {
  entry.data.tags.forEach((tag) => acc.set(tag, (acc.get(tag) ?? 0) + 1));
  return acc;
}, new Map<string, number>());
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="全部标签 - ai-productivity" description="按标签浏览 ai-productivity 的 AI 生产力内容。" canonical="/tags/">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Tags</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">全部标签</h1>
    <div class="mt-10 flex flex-wrap gap-3">
      {tags.map(([tag, count]) => (
        <a href={`/tags/${encodeURIComponent(tag)}/`} class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm transition hover:border-sky-200 hover:text-sky-700 hover:shadow">
          <span>#{tag}</span>
          <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-500">{count}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
