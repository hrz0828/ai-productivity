---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryPill from '../../components/CategoryPill.astro';
import { getAllPublishedEntries } from '../../utils/content';

const entries = await getAllPublishedEntries();
const categoryCounts = entries.reduce((acc, entry) => {
  acc.set(entry.data.category, (acc.get(entry.data.category) ?? 0) + 1);
  return acc;
}, new Map<string, number>());
const categories = [...categoryCounts.entries()].sort((a, b) => a[0].localeCompare(b[0], 'zh-CN'));
---

<BaseLayout title="全部分类 - ai-productivity" description="按主题分类浏览 ai-productivity 的 AI Prompt、Skill、Agent、Tool、Workflow 和 Guide。" canonical="/categories/">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Categories</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">全部分类</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">按具体工作场景浏览内容，快速找到文档、PPT、代码、研究、自动化等主题的 AI 工作方法。</p>
    <div class="mt-10 flex flex-wrap gap-3">
      {categories.map(([category, count]) => <CategoryPill label={category} count={count} />)}
    </div>
  </section>
</BaseLayout>
