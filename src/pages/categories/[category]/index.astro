---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import SearchEntry from '../../../components/SearchEntry.astro';
import { getAllPublishedEntries } from '../../../utils/content';
import { collectionPageJsonLd, itemListJsonLd } from '../../../utils/seo';

export async function getStaticPaths() {
  const entries = await getAllPublishedEntries();
  const categories = [...new Set(entries.map((entry) => entry.data.category))];

  return categories.map((category) => ({
    params: { category },
    props: {
      category,
      entries: entries.filter((entry) => entry.data.category === category),
      allEntries: entries,
    },
  }));
}

const { category, entries, allEntries } = Astro.props;
const title = `${category} 分类文章 - ai-productivity`;
const description = `浏览 ai-productivity 中 ${category} 分类下的 AI Prompt、Skill、Agent、Tool、Workflow 和 Guide。`;
const canonical = `/categories/${encodeURIComponent(category)}/`;
const isThinCategory = entries.length < 3;
const relatedEntries = allEntries
  .filter((entry) => entry.data.category !== category)
  .filter((entry) => entry.data.tags.some((tag) => entries.some((current) => current.data.tags.includes(tag))))
  .slice(0, 3);
const fallbackEntries = allEntries.filter((entry) => !entries.some((current) => current.id === entry.id && current.collection === entry.collection)).slice(0, 3);
const recommendations = relatedEntries.length ? relatedEntries : fallbackEntries;
const jsonLd = [
  collectionPageJsonLd({ title, description, url: canonical }),
  itemListJsonLd(entries.map((entry) => ({
    label: entry.data.title,
    description: entry.data.description,
    href: `/${entry.collection}/${entry.id}/`,
  }))),
];
---

<BaseLayout title={title} description={description} canonical={canonical} robots={isThinCategory ? 'noindex,follow' : 'index,follow'} jsonLd={jsonLd}>
  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[1fr_360px] lg:items-end">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Category</p>
          <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">{category}</h1>
          <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">共收录 {entries.length} 篇内容，覆盖该场景下可复用的 AI 工作方法、提示词、工具教程与自动化流程。</p>
          {isThinCategory && (
            <p class="mt-3 max-w-3xl text-base leading-7 text-amber-700">这个分类还在补充中。你可以先阅读当前内容，并结合下方推荐延伸阅读继续探索相近主题。</p>
          )}
          <div class="mt-6 flex flex-wrap gap-3 text-sm">
            <a class="font-medium text-sky-700 hover:text-sky-900" href="/categories/">← 返回全部分类</a>
            <a class="font-medium text-sky-700 hover:text-sky-900" href="/search/">搜索更多内容 →</a>
          </div>
        </div>
        <SearchEntry compact />
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mb-6 flex items-end justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Articles</p>
        <h2 class="mt-2 text-2xl font-bold text-slate-950">{category} 相关内容</h2>
      </div>
      <div class="text-sm text-slate-500">共 {entries.length} 篇</div>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {entries.map((entry) => <ArticleCard entry={entry} collection={entry.collection} />)}
    </div>
  </section>

  {isThinCategory && recommendations.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 pb-16 sm:px-6 lg:px-8">
      <div class="mb-6">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Related</p>
        <h2 class="mt-2 text-2xl font-bold text-slate-950">推荐延伸阅读</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">当前分类内容较少，先通过这些相近内容形成完整理解。</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {recommendations.map((entry) => <ArticleCard entry={entry} collection={entry.collection} />)}
      </div>
    </section>
  )}
</BaseLayout>
