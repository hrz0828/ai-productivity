---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getAllPublishedEntries } from '../../utils/content';

const entries = await getAllPublishedEntries();
const keywords = ['Agent', '智能体', '产品经理', '研究助理', 'SEO 编辑', '学习教练', '运营策划'];
const articles = entries.filter((entry) =>
  keywords.some((keyword) => entry.data.title.includes(keyword) || entry.data.category.includes(keyword) || entry.data.tags.some((tag) => tag.includes(keyword))),
).slice(0, 12);
---

<BaseLayout title="AI Agent 专题：角色设计、系统提示词和工作流程" description="汇总 AI Agent 相关内容，包括产品经理 Agent、研究助理 Agent、代码审查 Agent、学习教练和运营策划 Agent。" canonical="/topics/ai-agent/">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Topic</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">AI Agent 专题</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">Agent 比 Prompt 更强调角色、目标、流程、工具边界和持续协作。设计 Agent 的关键是明确它能做什么、不能做什么、何时需要人工确认。</p>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-xl font-semibold text-slate-950">角色定义</h2><p class="mt-3 text-sm leading-6 text-slate-600">说明 Agent 的专业角色、目标和判断标准。</p></div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-xl font-semibold text-slate-950">流程设计</h2><p class="mt-3 text-sm leading-6 text-slate-600">让 Agent 先澄清、再拆解、再输出、最后检查。</p></div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-xl font-semibold text-slate-950">边界控制</h2><p class="mt-3 text-sm leading-6 text-slate-600">高风险动作必须等待用户确认，不让 Agent 直接越权执行。</p></div>
    </div>
    <section class="mt-14">
      <h2 class="text-3xl font-bold text-slate-950">推荐内容</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {articles.map((entry) => <ArticleCard entry={entry} collection={entry.collection} />)}
      </div>
    </section>
  </section>
</BaseLayout>
