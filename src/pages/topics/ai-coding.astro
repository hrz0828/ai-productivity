---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getAllPublishedEntries } from '../../utils/content';

const entries = await getAllPublishedEntries();
const keywords = ['代码', '编程', 'Claude Code', 'Cursor', 'GitHub', 'Astro', 'Code Review'];
const articles = entries.filter((entry) =>
  keywords.some((keyword) => entry.data.title.includes(keyword) || entry.data.category.includes(keyword) || entry.data.tags.some((tag) => tag.includes(keyword))),
).slice(0, 12);
---

<BaseLayout title="AI 编程专题：Claude Code、Cursor、代码审查和部署" description="汇总 AI 编程相关内容，包括 Claude Code、Cursor、代码审查、GitHub Actions、Astro 和 Cloudflare Pages 部署。" canonical="/topics/ai-coding/">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Topic</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">AI 编程专题</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">AI 编程更适合做代码理解、任务拆解、样板生成、代码审查和测试补充。关键是让 AI 先理解上下文，再分步骤修改和验证。</p>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-950">代码理解</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">让 AI 找文件、解释调用链、梳理项目结构，降低进入陌生代码库的成本。</p>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-950">功能开发</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">先制定计划，再小步修改，最后运行构建或测试验证。</p>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-950">质量检查</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">用 AI 做提交前 Code Review，关注正确性、安全、性能和测试缺口。</p>
      </div>
    </div>

    <section class="mt-14">
      <h2 class="text-3xl font-bold text-slate-950">推荐内容</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {articles.map((entry) => <ArticleCard entry={entry} collection={entry.collection} />)}
      </div>
    </section>
  </section>
</BaseLayout>
