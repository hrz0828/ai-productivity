---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getAllPublishedEntries } from '../../utils/content';

const entries = await getAllPublishedEntries();
const keywords = ['写作', '文档', '邮件', '日报', '周报', '会议纪要', 'PRD', 'SEO', '简历'];
const articles = entries.filter((entry) =>
  keywords.some((keyword) => entry.data.title.includes(keyword) || entry.data.category.includes(keyword) || entry.data.tags.some((tag) => tag.includes(keyword))),
).slice(0, 12);
const readingPath = [
  { title: 'AI 写周报 Prompt', href: '/prompts/ai-weekly-report-prompt/', desc: '从高频办公写作开始，学习如何提供原始材料、检查夸大表达和修正风险描述。' },
  { title: 'AI 写 PRD Prompt', href: '/prompts/ai-prd-prompt/', desc: '把功能想法整理成可评审文档，重点学习事实、假设和待确认问题的区分。' },
  { title: 'AI SEO 文章工作流', href: '/workflows/seo-article-with-ai/', desc: '从关键词、搜索意图和结构规划进入内容创作，不只生成一篇泛泛文章。' },
  { title: 'AI 写作自动化指南', href: '/guides/ai-writing-automation-guide/', desc: '把单次 Prompt 升级成可复用的写作流程和检查清单。' },
];
---

<BaseLayout title="AI 写作专题：文档、邮件、周报、PRD 与 SEO 内容" description="围绕 AI 写作的专题页，汇总文档写作、邮件、日报周报、会议纪要、PRD、SEO 文章和简历优化内容。" canonical="/topics/ai-writing/">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Topic</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">AI 写作专题</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">从日常办公文档到内容站文章，AI 写作的关键不是让模型替你编造，而是把已有信息整理成结构清晰、可检查、可复用的文本。</p>

    <div class="mt-10 rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-2xl font-bold text-slate-950">这个专题应该怎么读？</h2>
      <p class="mt-4 text-base leading-8 text-slate-600">如果你只是复制一个 Prompt，很容易得到一篇语气顺滑但事实不稳的文章。更好的做法是先明确输入材料、写作对象和检查标准，再让 AI 生成初稿。本站会把写作类内容拆成三层：办公写作解决日常表达，产品文档解决协作边界，内容创作解决搜索意图和读者价值。</p>
      <p class="mt-3 text-base leading-8 text-slate-600">不建议把 AI 输出直接发布。尤其是周报、PRD、SEO 文章和简历优化，都需要人工复核事实、数据、语气和隐私信息。</p>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {readingPath.map((item, index) => (
          <a href={item.href} class="rounded-2xl border border-slate-200 bg-slate-50 p-5 transition hover:border-sky-200 hover:bg-sky-50">
            <div class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-700">Step {index + 1}</div>
            <h3 class="mt-2 text-lg font-semibold text-slate-950">{item.title}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-950">办公写作</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">日报、周报、会议纪要、邮件和项目复盘，适合从固定模板开始，但必须检查事实和语气。</p>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-950">产品文档</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">PRD、需求分析、SOP 和流程文档，需要明确输入、边界、验收标准和待确认问题。</p>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-950">内容创作</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">SEO 文章、公众号、小红书和内容日历，适合结合搜索意图、真实案例和后续复盘。</p>
      </div>
    </div>

    <section class="mt-14">
      <h2 class="text-3xl font-bold text-slate-950">推荐内容</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {articles.map((entry) => <ArticleCard entry={entry} collection={entry.collection} />)}
      </div>
    </section>
  </section>
</BaseLayout>
