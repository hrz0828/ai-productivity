---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getAllPublishedEntries } from '../../utils/content';

const entries = await getAllPublishedEntries();
const keywords = ['PPT', '演示', '大纲', '落地页', '文案'];
const articles = entries.filter((entry) =>
  keywords.some((keyword) => entry.data.title.includes(keyword) || entry.data.category.includes(keyword) || entry.data.tags.some((tag) => tag.includes(keyword))),
).slice(0, 12);
const readingOrder = [
  { label: '先定结构：PPT 大纲 Prompt', href: '/prompts/ai-ppt-outline-prompt/', note: '先明确受众、目标、页数和叙事结构。' },
  { label: '再走完整流程：AI PPT 工作流', href: '/workflows/create-ppt-with-ai/', note: '从主题到页面结构、内容展开和复核。' },
  { label: '补充表达：PPT 演讲稿 Prompt', href: '/prompts/ai-ppt-speaker-notes-prompt/', note: '为每页生成讲稿、过渡语和时间控制。' },
  { label: '角色化协作：PPT 策划 Agent', href: '/agents/ai-ppt-planner-agent/', note: '适合长期辅助汇报、培训和演示策划。' },
];
---

<BaseLayout title="AI PPT 专题：大纲、演示结构和页面文案" description="汇总 AI PPT 相关内容，包括 PPT 大纲、演示结构、页面文案、汇报材料和视觉建议。" canonical="/topics/ai-ppt/">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Topic</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">AI PPT 专题</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">AI 做 PPT 的重点不是直接生成漂亮页面，而是先明确受众、目标、叙事结构和每页核心观点，再进入设计和排版。</p>
    <section class="mt-10 rounded-[2rem] border border-sky-100 bg-sky-50/60 p-6 md:p-8">
      <h2 class="text-2xl font-bold text-slate-950">推荐阅读顺序</h2>
      <p class="mt-3 text-sm leading-6 text-slate-600">做 PPT 时建议先定结构，再展开页面内容，最后补充演讲稿和过渡语。</p>
      <ol class="mt-6 grid gap-4 md:grid-cols-2">
        {readingOrder.map((item, index) => (
          <li class="rounded-2xl border border-sky-100 bg-white p-5 shadow-sm">
            <div class="text-sm font-semibold text-sky-700">Step {index + 1}</div>
            <a href={item.href} class="mt-2 block font-semibold text-slate-950 hover:text-sky-700">{item.label}</a>
            <p class="mt-2 text-sm leading-6 text-slate-600">{item.note}</p>
          </li>
        ))}
      </ol>
    </section>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-xl font-semibold text-slate-950">大纲生成</h2><p class="mt-3 text-sm leading-6 text-slate-600">从主题、受众和演示目标生成页面级结构。</p></div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-xl font-semibold text-slate-950">内容展开</h2><p class="mt-3 text-sm leading-6 text-slate-600">为每页生成标题、要点、图示建议和演讲备注。</p></div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-xl font-semibold text-slate-950">设计评审</h2><p class="mt-3 text-sm leading-6 text-slate-600">检查信息层级、视觉焦点、文案和移动端阅读体验。</p></div>
    </div>
    <section class="mt-14">
      <h2 class="text-3xl font-bold text-slate-950">推荐内容</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {articles.map((entry) => <ArticleCard entry={entry} collection={entry.collection} />)}
      </div>
    </section>
  </section>
</BaseLayout>
