---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getAllPublishedEntries } from '../../utils/content';

const entries = await getAllPublishedEntries();
const keywords = ['内容站', 'SEO', 'AdSense', 'Search Console', '内容日历', 'Cloudflare', 'Astro'];
const articles = entries.filter((entry) =>
  keywords.some((keyword) => entry.data.title.includes(keyword) || entry.data.category.includes(keyword) || entry.data.tags.some((tag) => tag.includes(keyword))),
).slice(0, 12);
---

<BaseLayout title="AI 内容站专题：选题、SEO、部署和 AdSense" description="汇总 AI 内容站建设相关内容，包括选题、内容日历、Astro、Cloudflare Pages、Search Console 和 AdSense。" canonical="/topics/ai-content-site/">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Topic</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">AI 内容站专题</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">内容站不是只写文章，还需要定位、栏目、内容日历、SEO 基础、部署、收录和商业化准备。这个专题汇总从 0 到 1 的关键内容。</p>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-950">内容规划</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">确定目标用户、栏目结构、关键词和更新节奏。</p>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-950">技术上线</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">使用 Astro、GitHub 和 Cloudflare Pages 快速部署静态内容站。</p>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-950">SEO 与商业化</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">配置 sitemap、Search Console、AdSense 和基础监控。</p>
      </div>
    </div>

    <section class="mt-14">
      <h2 class="text-3xl font-bold text-slate-950">推荐内容</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {articles.map((entry) => <ArticleCard entry={entry} collection={entry.collection} />)}
      </div>
    </section>
  </section>
</BaseLayout>
