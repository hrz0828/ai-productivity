---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getAllPublishedEntries } from '../../utils/content';

const entries = await getAllPublishedEntries();
const keywords = ['自动化', 'n8n', 'Workflow', 'SOP', '内容日历', '会议'];
const articles = entries.filter((entry) =>
  keywords.some((keyword) => entry.data.title.includes(keyword) || entry.data.category.includes(keyword) || entry.data.tags.some((tag) => tag.includes(keyword))),
).slice(0, 12);
const readingPath = [
  { title: 'SOP 生成 Skill', href: '/skills/sop-generation-skill/', desc: '先把重复任务拆成稳定流程，再考虑自动化。' },
  { title: 'n8n AI 自动化教程', href: '/tools/n8n-ai-automation-guide/', desc: '理解表单、Webhook、AI 节点和人工确认如何连接。' },
  { title: '会议到行动项工作流', href: '/workflows/meeting-to-action-items/', desc: '从低风险办公场景开始练习自动化闭环。' },
  { title: '内容日历工作流', href: '/workflows/ai-content-calendar-workflow/', desc: '把选题、排期、内链和复盘指标放入可执行计划。' },
];
---

<BaseLayout title="AI 自动化专题：n8n、SOP、会议纪要和内容流程" description="汇总 AI 自动化相关内容，包括 n8n、SOP、会议行动项、内容日历和跨工具工作流。" canonical="/topics/ai-automation/">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Topic</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">AI 自动化专题</h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">AI 自动化适合处理高频、规则清晰、风险可控的重复任务。先标准化输入和输出，再考虑接入 n8n、表单、邮件或数据库。</p>

    <div class="mt-10 rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <h2 class="text-2xl font-bold text-slate-950">先判断任务是否值得自动化</h2>
      <p class="mt-4 text-base leading-8 text-slate-600">并不是所有任务都适合自动化。一个任务如果输入不稳定、判断高度依赖人、错误成本很高，贸然接入自动化反而会放大风险。比较稳妥的路线是：先写 SOP，再用 AI 处理其中低风险的文本整理环节，最后才把工具连接起来。</p>
      <p class="mt-3 text-base leading-8 text-slate-600">本专题优先推荐从会议纪要、内容排期、资料整理这类低风险任务开始。涉及删除、付款、公开发布、权限变更的动作，应保留人工确认。</p>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {readingPath.map((item, index) => (
          <a href={item.href} class="rounded-2xl border border-slate-200 bg-slate-50 p-5 transition hover:border-sky-200 hover:bg-sky-50">
            <div class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-700">Step {index + 1}</div>
            <h3 class="mt-2 text-lg font-semibold text-slate-950">{item.title}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-xl font-semibold text-slate-950">流程标准化</h2><p class="mt-3 text-sm leading-6 text-slate-600">先把重复任务变成 SOP、输入字段和检查清单。</p></div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-xl font-semibold text-slate-950">工具连接</h2><p class="mt-3 text-sm leading-6 text-slate-600">用 n8n 等工具连接表单、邮件、文档和 AI 模型。</p></div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"><h2 class="text-xl font-semibold text-slate-950">人工确认</h2><p class="mt-3 text-sm leading-6 text-slate-600">涉及公开发布、删除、付款等动作必须保留人工确认。</p></div>
    </div>
    <section class="mt-14">
      <h2 class="text-3xl font-bold text-slate-950">推荐内容</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {articles.map((entry) => <ArticleCard entry={entry} collection={entry.collection} />)}
      </div>
    </section>
  </section>
</BaseLayout>
