    <div class="mt-8 grid gap-6 lg:grid-cols-3">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-xl font-semibold text-slate-950">最新 Prompt</h3>
        <div class="mt-5 space-y-3">
          {newestPrompts.map((entry) => <a class="block text-sm font-medium leading-6 text-slate-700 hover:text-sky-700" href={getEntryHref(entry)}>{entry.data.title}</a>)}
        </div>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-xl font-semibold text-slate-950">最新 Workflow</h3>
        <div class="mt-5 space-y-3">
          {newestWorkflows.map((entry) => <a class="block text-sm font-medium leading-6 text-slate-700 hover:text-sky-700" href={getEntryHref(entry)}>{entry.data.title}</a>)}
        </div>
      </div>
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-xl font-semibold text-slate-950">最新 Tool</h3>
        <div class="mt-5 space-y-3">
          {newestTools.map((entry) => <a class="block text-sm font-medium leading-6 text-slate-700 hover:text-sky-700" href={getEntryHref(entry)}>{entry.data.title}</a>)}
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 pb-20 pt-8 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm md:p-10">
      <div class="grid gap-8 md:grid-cols-[1fr_1.2fr] md:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">About</p>
          <h2 class="mt-2 text-3xl font-bold text-slate-950">不是泛泛聊 AI，而是沉淀可复用工作方法</h2>
        </div>
        <p class="text-base leading-8 text-slate-600">ai-productivity 关注真实工作场景：文档、PPT、设计、代码、研究和自动化。每篇内容都尽量给出可复制模板、执行步骤和适用边界，帮助你把 AI 从聊天工具变成生产力系统。</p>
      </div>
    </div>
  </section>
</BaseLayout>
