---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CategoryPill from '../components/CategoryPill.astro';
import SearchEntry from '../components/SearchEntry.astro';
import QuickPromptShowcase from '../components/QuickPromptShowcase.astro';
import { COLLECTION_LABELS, TOPIC_ITEMS } from '../config';
import { hotSearchKeywords } from '../data/taskFinder';
import { getAllPublishedEntries } from '../utils/content';
import { itemListJsonLd, organizationJsonLd, websiteJsonLd } from '../utils/seo';

const entries = await getAllPublishedEntries();
const getEntryKey = (entry: (typeof entries)[number]) => `${entry.collection}/${entry.id}`;
const getEntryHref = (entry: (typeof entries)[number]) => `/${entry.collection}/${entry.id}/`;
const excludeEntries = (source: typeof entries, used: Set<string>, limit: number) => source.filter((entry) => !used.has(getEntryKey(entry))).slice(0, limit);

const featured = entries.filter((entry) => entry.data.featured).slice(0, 6);
const workflows = entries.filter((entry) => entry.collection === 'workflows').slice(0, 3);
const prompts = entries.filter((entry) => entry.collection === 'prompts').slice(0, 3);
const tools = entries.filter((entry) => entry.collection === 'tools').slice(0, 3);
const categoryCounts = entries.reduce((acc, entry) => {
  acc.set(entry.data.category, (acc.get(entry.data.category) ?? 0) + 1);
  return acc;
}, new Map<string, number>());
const collectionCounts = entries.reduce((acc, entry) => {
  acc.set(entry.collection, (acc.get(entry.collection) ?? 0) + 1);
  return acc;
}, new Map<string, number>());
const topCategories = [...categoryCounts.entries()].filter(([, count]) => count >= 2).sort((a, b) => b[1] - a[1]).slice(0, 12);
const collectionLinks = Object.entries(COLLECTION_LABELS).map(([collection, label]) => ({
  label,
  href: `/${collection}/`,
  count: collectionCounts.get(collection as keyof typeof COLLECTION_LABELS) ?? 0,
}));
const heroSearchKeywords = hotSearchKeywords.slice(0, 8);
const homeTitle = 'AI 生产力实战库：Prompt、Agent、Workflow 与工具教程';
const homeDescription = '收录可复制的 AI 提示词、自动化工作流、Agent 配置和工具教程，帮助你提升写作、PPT、产品、编程、知识管理和内容创作效率。';
const jsonLd = [
  websiteJsonLd(),
  organizationJsonLd(),
  itemListJsonLd(featured.slice(0, 8).map((entry) => ({
    label: entry.data.title,
    description: entry.data.description,
    href: getEntryHref(entry),
  }))),
];
const stats = [
  { label: '原创内容', value: `${entries.length}+` },
  { label: '内容类型', value: `${collectionLinks.length}` },
  { label: '成熟主题', value: `${topCategories.length}+` },
];
const scenarioCards = [
  {
    title: '写周报 / 日报',
    audience: '职场写作、团队同步',
    output: '结构化工作汇报',
    href: '/prompts/ai-weekly-report-prompt/',
  },
  {
    title: '写 PRD / 需求文档',
    audience: '产品经理、项目负责人',
    output: '需求文档与执行路径',
    href: '/workflows/write-prd-with-ai/',
  },
  {
    title: '快速生成 PPT 大纲',
    audience: '汇报、培训、方案展示',
    output: '可展开的演示结构',
    href: '/workflows/create-ppt-with-ai/',
  },
  {
    title: '整理会议纪要',
    audience: '项目协作、管理同步',
    output: '纪要、结论和行动项',
    href: '/workflows/meeting-to-action-items/',
  },
  {
    title: '做竞品分析',
    audience: '产品、运营、市场研究',
    output: '竞品维度和分析报告',
    href: '/workflows/competitive-analysis-with-ai/',
  },
  {
    title: '把文章改成短视频',
    audience: '内容运营、知识博主',
    output: '脚本、分镜和配音提示词',
    href: '/workflows/article-to-short-video-workflow/',
  },
];
const conceptCards = [
  {
    name: 'Prompt',
    title: '直接复制提示词',
    description: '适合马上完成一次具体任务，例如写周报、生成大纲或改写邮件。',
    href: '/prompts/',
  },
  {
    name: 'Workflow',
    title: '跟着步骤完成任务',
    description: '适合复杂任务，把 Prompt、工具、人工检查点组合成完整路径。',
    href: '/workflows/',
  },
  {
    name: 'Skill',
    title: '沉淀可复用能力',
    description: '适合反复完成同类任务，把输入、步骤、输出格式沉淀下来。',
    href: '/skills/',
  },
  {
    name: 'Agent',
    title: '搭建自动执行助手',
    description: '适合持续处理一类问题，例如产品经理 Agent、SEO 编辑 Agent。',
    href: '/agents/',
  },
];
const casePaths = [
  {
    title: '我要做一份竞品分析',
    steps: [
      { label: '用 Prompt 明确分析维度', href: '/prompts/ai-competitor-analysis-prompt/' },
      { label: '用 Workflow 输出完整报告', href: '/workflows/competitive-analysis-with-ai/' },
      { label: '用 PPT 大纲沉淀汇报结构', href: '/prompts/ai-ppt-outline-prompt/' },
    ],
  },
  {
    title: '我要从零分析并写一份 PRD',
    steps: [
      { label: '先判断需求是否值得做', href: '/workflows/demand-analysis-with-ai/' },
      { label: '再生成 PRD 初稿', href: '/prompts/ai-prd-prompt/' },
      { label: '交给产品经理 Agent 复核', href: '/agents/ai-product-manager-agent/' },
    ],
  },
  {
    title: '我要搭建个人知识库',
    steps: [
      { label: '选择 Notion 或 Obsidian 工具链', href: '/topics/ai-knowledge-management/' },
      { label: '搭建知识库工作流', href: '/workflows/personal-knowledge-base-with-ai/' },
      { label: '用研究总结 Skill 处理资料', href: '/skills/research-summary-skill/' },
    ],
  },
  {
    title: '我要把文章改成短视频',
    steps: [
      { label: '先拆成长文转视频流程', href: '/workflows/article-to-short-video-workflow/' },
      { label: '再选择 AI 视频生成工具', href: '/tools/ai-video-generation-tools-guide/' },
      { label: '补充图像 Prompt 模板', href: '/prompts/ai-image-prompt-template/' },
    ],
  },
];
const learningPaths = [
  {
    title: '从 Prompt 入门',
    description: '适合第一次系统使用 AI 提升办公效率的读者。',
    links: [
      { label: 'Prompt、Skill、Agent、Workflow 有什么区别？', href: '/guides/prompt-skill-agent-workflow/' },
      { label: '如何写出高质量 Prompt', href: '/guides/high-quality-prompt-guide/' },
      { label: 'AI 工具选型指南', href: '/guides/ai-tools-selection-guide/' },
    ],
  },
  {
    title: '搭建内容工作流',
    description: '适合需要持续写文章、做 SEO 和沉淀模板的人。',
    links: [
      { label: 'AI SEO 文章写作工作流', href: '/workflows/seo-article-with-ai/' },
      { label: 'SEO Brief 生成 Skill', href: '/skills/seo-brief-skill/' },
      { label: 'AI SEO 编辑 Agent', href: '/agents/ai-seo-editor-agent/' },
    ],
  },
  {
    title: '多模态工具链',
    description: '适合从文字扩展到图像、视频和语音智能体。',
    links: [
      { label: '多模态 AI 专题', href: '/topics/ai-multimodal/' },
      { label: 'Midjourney 提示词入门', href: '/guides/midjourney-prompt-beginner-guide/' },
      { label: 'Voice Agent 入门', href: '/tools/voice-agent-beginner-guide/' },
    ],
  },
];
const usedInFocusedModules = new Set([...featured, ...tools, ...workflows, ...prompts].map(getEntryKey));
[...scenarioCards, ...casePaths.flatMap((path) => path.steps), ...learningPaths.flatMap((path) => path.links)].forEach((item) => {
  const [, collection, slug] = item.href.match(/^\/(prompts|skills|agents|tools|workflows|guides)\/([^/]+)\//) ?? [];
  if (collection && slug) usedInFocusedModules.add(`${collection}/${slug}`);
});
const latest = excludeEntries(entries, usedInFocusedModules, 6);
const usedBeforeExplore = new Set([...usedInFocusedModules, ...latest.map(getEntryKey)]);
const newestPrompts = excludeEntries(entries.filter((entry) => entry.collection === 'prompts'), usedBeforeExplore, 4);
const newestWorkflows = excludeEntries(entries.filter((entry) => entry.collection === 'workflows'), usedBeforeExplore, 4);
const newestTools = excludeEntries(entries.filter((entry) => entry.collection === 'tools'), usedBeforeExplore, 4);
const topicDetails = TOPIC_ITEMS.map((topic) => ({
  ...topic,
  description: ({
    'AI 写作': '周报、邮件、PRD、SEO 文章和内容创作模板。',
    'AI 产品经理': '从需求分析到 PRD，再到产品经理 Agent 复核。',
    'AI 编程': 'Claude Code、Cursor、代码审查和部署自动化。',
    'AI 知识管理': 'Notion、Obsidian、资料总结和个人知识库。',
    'AI 设计评审': 'Figma、设计 Brief、页面评审和用户体验检查。',
    'AI PPT': 'PPT 大纲、演示结构、页面文案和设计评审。',
    'AI 会议效率': '会议纪要、行动项、会后跟进和会议 Agent。',
    'AI 自动化': 'n8n、工作流自动化和重复任务处理。',
    'AI Agent': '智能体角色、系统提示词、边界和工作流程。',
    '多模态 AI': 'AI 视频、图像设计、语音智能体和数字人工作流。',
    'AI 内容站': '内容站 SEO、部署、Search Console 和 AdSense。',
  } as Record<string, string>)[topic.label] ?? '围绕该主题系统阅读和实践。',
}));
const coreTopicItems = topicDetails.slice(0, 6);
const moreTopicItems = topicDetails.slice(6);
---

<BaseLayout title={homeTitle} description={homeDescription} canonical="/" jsonLd={jsonLd}>
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-x-0 top-0 h-64 bg-gradient-to-b from-sky-50 to-transparent"></div>
    <div class="relative mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.25em] text-sky-700">AI Productivity Playbook</p>
          <h1 class="mt-5 text-5xl font-bold tracking-tight text-slate-950 sm:text-6xl">AI 生产力实战库：用 Prompt、Agent 和 Workflow 重构日常工作</h1>
          <p class="mt-6 max-w-3xl text-xl leading-9 text-slate-600">系统整理可复制的 AI 提示词、自动化工作流、Agent 配置和工具教程，提升写作、PPT、产品、编程、知识管理和内容创作效率。</p>
          <div class="mt-8"><SearchEntry /></div>
          <div class="mt-4 flex flex-wrap items-center gap-2">
            <span class="text-sm font-medium text-slate-500">热门搜索：</span>
            {heroSearchKeywords.map((keyword) => (
              <a href={`/search/?q=${encodeURIComponent(keyword)}`} class="rounded-full border border-slate-200 bg-white px-3 py-1.5 text-sm font-medium text-slate-600 transition hover:border-sky-200 hover:bg-sky-50 hover:text-sky-700">{keyword}</a>
            ))}
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#quick-prompts" class="rounded-full bg-sky-600 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-700 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-offset-2">复制热门 Prompt</a>
            <a href="/tasks/" class="rounded-full border border-slate-300 px-6 py-3 text-sm font-semibold text-slate-700 transition hover:border-sky-300 hover:text-sky-700">按任务查找</a>
          </div>
        </div>
        <div class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-2xl">
          <div class="flex items-center justify-between gap-4">
            <div class="text-sm font-medium text-sky-200">本站适合解决</div>
            <a href="/resources/" class="text-xs font-medium text-slate-300 hover:text-white">查看资源合集 →</a>
          </div>
          <div class="mt-5 grid gap-3 sm:grid-cols-2">
            {scenarioCards.map((item) => (
              <a href={item.href} class="rounded-2xl bg-white/10 p-4 text-sm leading-6 text-slate-100 transition hover:bg-white/15">
                <div class="font-semibold text-white">{item.title}</div>
                <div class="mt-2 text-xs text-slate-300">适合：{item.audience}</div>
                <div class="mt-1 text-xs text-sky-100">产出：{item.output}</div>
                <div class="mt-3 text-xs font-medium text-sky-200">进入解决方案 →</div>
              </a>
            ))}
          </div>
          <div class="mt-6 grid grid-cols-3 gap-3 border-t border-white/10 pt-6">
            {stats.map((stat) => (
              <div>
                <div class="text-2xl font-bold text-white">{stat.value}</div>
                <div class="mt-1 text-xs text-slate-300">{stat.label}</div>
              </div>
            ))}
          </div>
          <div class="mt-5 rounded-2xl bg-white/10 p-4">
            <div class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-200">栏目直达</div>
            <div class="mt-3 flex flex-wrap gap-2">
              {collectionLinks.map((item) => (
                <a href={item.href} class="rounded-full bg-white/10 px-3 py-1.5 text-xs font-medium text-slate-100 transition hover:bg-white/20 hover:text-white">{item.label} · {item.count}</a>
              ))}
            </div>
          </div>
          <div class="mt-3 flex flex-wrap gap-2 text-xs">
            {topCategories.slice(0, 6).map(([category, count]) => (
              <a href={`/categories/${encodeURIComponent(category)}/`} class="rounded-full border border-white/10 px-3 py-1.5 font-medium text-sky-100 transition hover:border-sky-200 hover:text-white">{category} {count}</a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <QuickPromptShowcase />

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <div class="grid gap-6 lg:grid-cols-[1fr_320px] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Task finder</p>
          <h2 class="mt-2 text-3xl font-bold text-slate-950">不知道该找 Prompt、Skill 还是 Workflow？</h2>
          <p class="mt-3 text-base leading-7 text-slate-600">直接按“我要完成什么任务”浏览：写周报、做 PRD、竞品分析、代码审查、知识库搭建等场景已经整理好推荐路径。</p>
        </div>
        <a href="/tasks/" class="inline-flex justify-center rounded-full bg-slate-950 px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800">按任务找工具 →</a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <SectionHeader eyebrow="Start here" title="不知道从哪里开始？先按任务复杂度选择" description="如果只是马上完成一件事，先复制 Prompt；如果想按流程做完一件事，选择 Workflow；如果任务经常重复，沉淀成 Skill；如果需要持续判断，设计 Agent。" href="/guides/prompt-skill-agent-workflow/" />
    <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {conceptCards.map((concept) => (
        <a href={concept.href} class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-sky-200 hover:shadow-lg">
          <div class="text-sm font-semibold uppercase tracking-[0.16em] text-sky-700">{concept.name}</div>
          <h2 class="mt-3 text-lg font-semibold leading-snug text-slate-950">{concept.title}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-600">{concept.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <SectionHeader eyebrow="Core Topics" title="热门主题" description="只展示已有多篇内容支撑的成熟主题，避免进入后只有单篇内容。" href="/categories/" />
    <div class="mt-6 flex flex-wrap gap-3">
      {topCategories.map(([category, count]) => <CategoryPill label={category} count={count} />)}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <SectionHeader eyebrow="Use Cases" title="典型案例路径" description="从一个真实问题出发，按 Prompt、Skill、Agent、Workflow 的组合路径完成任务。" />
    <div class="mt-8 grid gap-6 lg:grid-cols-3">
      {casePaths.map((path) => (
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-xl font-semibold text-slate-950">{path.title}</h2>
          <ol class="mt-5 space-y-4">
            {path.steps.map((step, index) => (
              <li class="flex gap-3 text-sm leading-6">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-sky-50 text-xs font-semibold text-sky-700">{index + 1}</span>
                <a href={step.href} class="font-medium text-slate-700 hover:text-sky-700">{step.label}</a>
              </li>
            ))}
          </ol>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <SectionHeader eyebrow="Featured" title="精选内容" description="优先阅读这些可复用的 AI 工作方法，快速理解本站内容结构。" />
    <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {(featured.length ? featured : latest).map((entry) => <ArticleCard entry={entry} collection={entry.collection} />)}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <SectionHeader eyebrow="Topics" title="专题入口" description="优先展示已经形成内容簇的核心专题，适合围绕一个方向连续学习和实践。" />
    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {coreTopicItems.map((topic) => (
        <a href={topic.href} class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-sky-200 hover:shadow-lg">
          <div class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">Core topic</div>
          <div class="mt-3 text-xl font-semibold text-slate-950">{topic.label}</div>
          <p class="mt-3 text-sm leading-6 text-slate-600">{topic.description}</p>
          <div class="mt-5 text-sm font-medium text-sky-700">查看专题内容 →</div>
        </a>
      ))}
    </div>
    {moreTopicItems.length > 0 && (
      <div class="mt-6 rounded-3xl border border-slate-200 bg-slate-50 p-5">
        <div class="text-sm font-semibold text-slate-950">更多专题</div>
        <div class="mt-3 flex flex-wrap gap-3">
          {moreTopicItems.map((topic) => (
            <a href={topic.href} class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition hover:border-sky-200 hover:text-sky-700">{topic.label}</a>
          ))}
        </div>
      </div>
    )}
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <SectionHeader eyebrow="Start here" title="推荐阅读路径" description="如果不知道从哪里开始，可以按下面三条路径逐步阅读和实践。" />
    <div class="mt-8 grid gap-6 lg:grid-cols-3">
      {learningPaths.map((path) => (
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-xl font-semibold text-slate-950">{path.title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-600">{path.description}</p>
          <ol class="mt-5 space-y-3">
            {path.links.map((link, index) => (
              <li class="flex gap-3 text-sm leading-6">
                <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-sky-50 text-xs font-semibold text-sky-700">{index + 1}</span>
                <a class="font-medium text-slate-700 hover:text-sky-700" href={link.href}>{link.label}</a>
              </li>
            ))}
          </ol>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <SectionHeader eyebrow="Workflows" title="实战工作流精选" description="从输入到输出的多步骤方案，更适合处理 PRD、竞品分析、代码审查等复杂任务。" href="/workflows/" />
    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {workflows.map((entry) => <ArticleCard entry={entry} collection={entry.collection} />)}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-2">
      <div>
        <SectionHeader eyebrow="Prompts" title="可复制 Prompt" description="适合单次任务和快速试用。" href="/prompts/" />
        <div class="mt-6 space-y-4">
          {prompts.map((entry) => <ArticleCard entry={entry} collection={entry.collection} />)}
        </div>
      </div>
      <div>
