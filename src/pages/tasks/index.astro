---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SearchEntry from '../../components/SearchEntry.astro';
import { taskGroups } from '../../data/taskFinder';

const typeStyles: Record<string, string> = {
  Prompt: 'bg-sky-50 text-sky-700',
  Workflow: 'bg-indigo-50 text-indigo-700',
  Skill: 'bg-emerald-50 text-emerald-700',
  Agent: 'bg-violet-50 text-violet-700',
  Tool: 'bg-amber-50 text-amber-700',
  Guide: 'bg-slate-100 text-slate-700',
  Topic: 'bg-rose-50 text-rose-700',
};
const taskCount = taskGroups.reduce((count, group) => count + group.tasks.length, 0);
---

<BaseLayout title="按任务找 AI 工具和 Prompt - ai-productivity" description="按具体任务浏览 AI Prompt、Workflow、Skill、Agent 和工具教程，快速找到适合职场写作、产品经理、内容创作、编程和知识管理的 AI 工作方法。" canonical="/tasks/">
  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[1fr_360px] lg:items-end">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Task finder</p>
          <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">按任务找 AI 工具和 Prompt</h1>
          <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">不需要先理解 Prompt、Skill、Agent、Workflow 的区别。直接从“我想完成什么任务”出发，找到可复制模板、完整流程和工具教程。</p>
          <div class="mt-6 flex flex-wrap gap-3 text-sm text-slate-600">
            <span class="rounded-full bg-sky-50 px-4 py-2 font-medium text-sky-700">{taskGroups.length} 个任务场景</span>
            <span class="rounded-full bg-slate-100 px-4 py-2 font-medium text-slate-700">{taskCount} 个具体任务</span>
            <span class="rounded-full bg-slate-100 px-4 py-2 font-medium text-slate-700">Prompt / Workflow / Tool 一起推荐</span>
          </div>
        </div>
        <SearchEntry compact />
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="rounded-3xl border border-sky-100 bg-sky-50/70 p-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div>
          <h2 class="text-2xl font-bold text-slate-950">快速跳到任务类别</h2>
          <p class="mt-2 text-sm leading-6 text-slate-600">如果你不知道该选 Prompt 还是 Workflow，先选任务类别。</p>
        </div>
        <a href="/guides/prompt-skill-agent-workflow/" class="text-sm font-semibold text-sky-700 hover:text-sky-900">理解核心概念 →</a>
      </div>
      <div class="mt-5 flex flex-wrap gap-3">
        {taskGroups.map((group) => (
          <a href={`#${group.id}`} class="rounded-full border border-sky-100 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-sky-200 hover:text-sky-700">{group.title}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl space-y-12 px-4 pb-16 sm:px-6 lg:px-8">
    {taskGroups.map((group) => (
      <section id={group.id} class="scroll-mt-24">
        <div class="mb-6">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">Scenario</p>
          <h2 class="mt-2 text-3xl font-bold text-slate-950">{group.title}</h2>
          <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">{group.description}</p>
        </div>
        <div class="grid gap-6 lg:grid-cols-3">
          {group.tasks.map((task) => (
            <article class="flex h-full flex-col rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-sky-200 hover:shadow-lg">
              <div class="flex flex-wrap gap-2 text-xs font-medium">
                <span class="rounded-full bg-slate-100 px-3 py-1 text-slate-600">{task.audience}</span>
                <span class="rounded-full bg-sky-50 px-3 py-1 text-sky-700">{task.difficulty}</span>
              </div>
              <h3 class="mt-4 text-xl font-semibold leading-snug text-slate-950">{task.title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-600">{task.intent}</p>
              <div class="mt-5 flex-1 space-y-3">
                {task.links.map((link) => (
                  <a href={link.href} class="flex items-center justify-between gap-3 rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm transition hover:border-sky-200 hover:bg-sky-50">
                    <span class="font-semibold leading-5 text-slate-800">{link.label}</span>
                    <span class:list={['shrink-0 rounded-full px-2.5 py-1 text-xs font-semibold', typeStyles[link.type] ?? typeStyles.Guide]}>{link.type}</span>
                  </a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}
  </section>
</BaseLayout>

<script is:inline>
  document.addEventListener('click', (event) => {
    const link = event.target.closest('a[href]');
    if (!link || !link.closest('[id]')) return;
    window.trackInteraction?.('task_finder_click', {
      href: link.getAttribute('href'),
      text: link.textContent?.trim(),
      page_path: window.location.pathname,
    });
  });
</script>
